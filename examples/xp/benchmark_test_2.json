{
    "type": "pages",
    "headline": "Drawing Plugin",
    "pages": [{  
            "items": [{           
                    "type": "default",
                    "layout": "0,0,12,6",
                    "color": "msx-glass",
                    "icon": "msx-white-soft:color-lens",
                    "iconSize": "large",
                    "title": "Start Drawing",                    
